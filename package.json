{
  "name": "vitesakuga",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "db": "drizzle-kit",
    "dcd": "docker compose down",
    "dcu": "docker compose up -d",
    "dev": "vite dev --mode development",
    "dev:prod": "vite dev --mode production",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "infra:deploy": "alchemy deploy infra/alchemy.run.ts",
    "infra:dev": "alchemy dev infra/alchemy.run.ts",
    "infra:destroy": "alchemy destroy infra/alchemy.run.ts",
    "knip": "knip",
    "lint": "oxlint . --fix",
    "lint:check": "oxlint .",
    "neonctl": "neonctl",
    "prepare": "effect-language-service patch",
    "server": "vite preview",
    "start": "node run .output/server/index.mjs",
    "test": "vitest -w",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:lightpanda": "CDP_HTTP=http://127.0.0.1:9223 E2E_CONFIG=e2e/playwright.lightpanda.config.ts node e2e/setup-cdp.mjs",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "tz": "taze major -a -f",
    "wrangler:dev": "wrangler pages dev --proxy 3000 -- pnpm vite dev --mode development",
    "wrangler:preview": "wrangler pages dev .output/public"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@aws-sdk/node-http-handler": "^3.374.0",
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-form-devtools": "^0.2.22",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-pacer": "^0.22.0",
    "@tanstack/react-pacer-devtools": "0.7.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "^1.167.65",
    "@xstate/react": "^6.1.0",
    "better-auth": "1.6.9",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "effect": "4.0.0-beta.59",
    "isomorphic-dompurify": "^3.12.0",
    "kysely": "^0.28.17",
    "lodash-es": "^4.18.1",
    "media-chrome": "^4.19.0",
    "mediabunny": "^1.44.1",
    "mediainfo.js": "^0.3.7",
    "neonctl": "^2.22.0",
    "next-themes": "^0.4.6",
    "nitro": "3.0.260429-beta",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "taze": "^19.11.0",
    "use-sync-external-store": "^1.6.0",
    "vite-plugin-static-copy": "^4.1.0",
    "xstate": "^5.31.0",
