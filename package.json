    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.20",
    "@xstate/react": "^6.1.0",
    "better-auth": "1.6.14",
    "date-fns": "^4.4.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "effect": "4.0.0-beta.59",
    "isomorphic-dompurify": "^3.15.0",
