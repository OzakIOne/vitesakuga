{
  "name": "vitesakuga",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "db": "drizzle-kit",
    "dcd": "docker compose down",
    "dcu": "docker compose up -d",
    "dev": "vite dev --mode development --host",
    "dev:local": "vite dev --mode test --host",
    "dev:prod": "vite dev --mode production",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "infra:deploy": "alchemy deploy infra/alchemy.run.ts",
    "infra:dev": "alchemy dev infra/alchemy.run.ts",
    "infra:destroy": "alchemy destroy infra/alchemy.run.ts",
    "knip": "knip",
    "lint": "oxlint . --fix",
    "lint:check": "oxlint .",
    "oc": "opencode web --hostname 0.0.0.0 --mdns",
    "neonctl": "neonctl",
    "prepare": "effect-language-service patch && effect-tsgo patch",
    "server": "vite preview",
    "start": "node .output/server/index.mjs",
    "test": "vitest -w",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:lightpanda": "CDP_HTTP=http://127.0.0.1:9223 E2E_CONFIG=e2e/playwright.lightpanda.config.ts node e2e/setup-cdp.mjs",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "tz": "taze major -a -f",
    "wrangler:dev": "wrangler pages dev --proxy 3000 -- pnpm vite dev --mode development",
    "wrangler:preview": "wrangler pages dev .output/public",
    "look": "bun scripts/lookup-opencode-session.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@chakra-ui/react": "^3.36.0",
    "@effect/opentelemetry": "4.0.0-beta.59",
    "@emotion/react": "^11.14.0",
    "@neondatabase/serverless": "^1.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/db": "^0.6.8",
    "@tanstack/query-db-collection": "^1.0.40",
    "@tanstack/react-db": "^0.1.86",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-form-devtools": "^0.2.29",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-pacer-devtools": "0.7.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.25",
    "@xstate/react": "^6.1.0",
    "alchemy": "2.0.0-beta.61",
    "better-auth": "1.6.18",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "effect": "4.0.0-beta.59",
    "isomorphic-dompurify": "^3.17.0",
    "kysely": "^0.29.2",
    "media-chrome": "^4.19.2",
    "mediabunny": "^1.46.0",
    "mediainfo.js": "^0.3.7",
    "neonctl": "^2.26.4",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "xstate": "^5.32.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.2",
    "@cloudflare/workers-types": "^4.20260615.1",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.86.2",
    "@effect/tsgo": "0.14.4",
    "@electric-sql/pglite": "^0.5.2",
    "@playwright/test": "^1.61.0",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/eslint-plugin-query": "^5.101.0",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260615.1",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "drizzle-seed": "^0.3.1",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "nitro": "3.0.260610-beta",
    "oxfmt": "0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "tailwindcss": "^4.3.1",
    "taze": "^19.14.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.100.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "download"
    }
  }
}
